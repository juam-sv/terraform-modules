terraform {
  source = "{{ .SourceURL }}"
}

include "root" {
  path = find_in_parent_folders("root.hcl")
}

inputs = {
  tags = {
    Environment = "dev"
    ManagedBy   = "terragrunt"
  }

  secrets = {
    example_secret = {
      name                    = "my-app/example-secret"
      description             = "Example secret for my application"
      recovery_window_in_days = 7
      tags = {
        Purpose = "example"
      }
    }
  }
}
